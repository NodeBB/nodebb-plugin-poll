<div data-option-id="{./id}" class="d-flex align-items-center justify-content-between gap-2">
	<input type="text" name="options" id="pollInputOptions" value="{./title}" class="form-control"/>
	<input type="hidden" name="id" value="{./id}"/>
	<button class="btn btn-ghost btn-sm" data-action="remove-option" data-option-id="{./id}"><i class="fa fa-trash text-danger"></i></button>
</div>